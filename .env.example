# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Telegram bot credentials. Create a bot with @BotFather, then add it to your
# target chat/group and grab the chat ID (for groups, prefix with `-100`).
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Alert threshold: fire when a symbol moves this percent or more within the
# rolling window.
PUMP_THRESHOLD_PCT=2.0

# Size of the rolling price window, in seconds.
WINDOW_SECONDS=60

# After an alert on a symbol, suppress further alerts on that symbol for this
# many minutes.
COOLDOWN_MINUTES=15

# Only watch pairs ending in this quote currency.
QUOTE_CURRENCY=USDT

# Comma-separated suffix blocklist. Leveraged tokens are noisy and not real
# spot — filter them out.
EXCLUDE_SUFFIXES=UPUSDT,DOWNUSDT,BULLUSDT,BEARUSDT

# Log level. One of: debug, info, warn, error.
LOG_LEVEL=info

# Blox coin-list page scraped for the supported-asset filter. Only pumps on
# coins listed here will be forwarded to Telegram — the Telegram message
# links directly to the coin's Blox trading page.
BLOX_COINS_URL=https://weareblox.com/nl-nl/cryptocurrency-coins

# How often to refresh the Blox coin list (hours). Default 6.
BLOX_REFRESH_HOURS=6

# Minimum elapsed seconds between the window's min price and the alert-firing
# tick. Prevents a single-tick spike from triggering an alert. 0 = no floor.
MIN_ELAPSED_SECONDS=0

# Hard cap on Telegram messages per second. Telegram's documented limit is
# 30/s to a single chat; we stay well under. Range: 1–30.
TELEGRAM_RATE_LIMIT_PER_SEC=20

# WebSocket silence watchdog: if no tick arrives within this many seconds,
# force a reconnect. Default 30.
SILENCE_TIMEOUT_SECONDS=30

# Optional override for the Binance WebSocket URL. Leave blank/unset to use
# the production stream `wss://stream.binance.com:9443/ws/!miniTicker@arr`.
# Mostly useful for integration tests pointing at a local WS server.
# BINANCE_WS_URL=

# After an initial pump alert, the bot keeps watching the symbol for follow-up
# "escalation" alerts so you don't get silenced through the bulk of the move.
# Each tier (in % above the initial alert's fromPrice) fires at most once per
# active pump. The series ends when the highest tier fires or the window
# below expires. Comma-separated, default `5,10,20,50`. Set to an empty value
# to disable escalation alerts entirely.
ESCALATION_TIERS_PCT=5,10,20,50

# How long after the initial alert to keep watching for escalations, in
# minutes. 0 disables escalations regardless of the tier list. Range 0–240.
ESCALATION_WINDOW_MINUTES=15
